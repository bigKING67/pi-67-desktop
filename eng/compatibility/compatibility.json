{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schemaVersion": 1,
  "desktopVersion": "0.1.0-alpha.1",
  "releaseChannel": "alpha",
  "platform": {
    "operatingSystems": [
      {
        "name": "Windows 10",
        "minimumRelease": "22H2",
        "minimumBuild": 19045
      },
      {
        "name": "Windows 11",
        "minimumRelease": "22H2",
        "minimumBuild": 22621
      }
    ],
    "architectures": [
      "x64"
    ]
  },
  "runtime": {
    "dotnetDesktop": "10.0",
    "windowsAppSdk": "2.3.1",
    "node": {
      "major": 24,
      "tested": "24.18.0"
    },
    "npm": {
      "major": 11,
      "tested": "11.16.0"
    },
    "pi": {
      "package": "@earendil-works/pi-coding-agent",
      "minimum": "0.80.0",
      "tested": "0.80.6",
      "newerPolicy": "unverified-but-rpc-allowed"
    },
    "pi67": {
      "managerPackage": "@bigking67/pi-67",
      "tested": "0.14.3"
    }
  },
  "deployment": {
    "dotnet": "framework-dependent",
    "windowsAppSdk": "framework-dependent",
    "embeddedPiRuntime": false,
    "embeddedNodeRuntime": false
  }
}
