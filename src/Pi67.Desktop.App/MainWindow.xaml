<Window
    x:Class="Pi67.Desktop.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Pi67.Desktop.App.Views">
    <Grid Background="{ThemeResource Pi67CanvasBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="12,0"
            Background="{ThemeResource Pi67TitleBarBrush}"
            BorderBrush="{ThemeResource Pi67DividerBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE943;" FontSize="14" />
                <TextBlock
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="Pi-67 Desktop" />
                <TextBlock
                    Grid.Column="2"
                    Margin="12,0,140,0"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding OperationStatus}" />
            </Grid>
        </Border>

        <views:ShellPage x:Name="Shell" Grid.Row="1" />
    </Grid>
</Window>
