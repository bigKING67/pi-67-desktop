<Page
    x:Class="Pi67.Desktop.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Pi67.Desktop.App.Controls"
    xmlns:converters="using:Pi67.Desktop.App.Converters">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:BooleanToVisibilityConverter x:Key="InverseBoolToVisibility" Invert="True" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavigationColumn" Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1128" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="MediumWide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1040" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="NavigationColumn.Width" Value="208" />
                        <Setter Target="ContextSplitView.OpenPaneLength" Value="300" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Medium">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="760" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ContextSplitView.DisplayMode" Value="Overlay" />
                        <Setter Target="ContextSplitView.IsPaneOpen" Value="False" />
                        <Setter Target="OverlayToolbar.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Compact">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="NavigationColumn.Width" Value="0" />
                        <Setter Target="NavigationPane.Visibility" Value="Collapsed" />
                        <Setter Target="ContextSplitView.DisplayMode" Value="Overlay" />
                        <Setter Target="ContextSplitView.IsPaneOpen" Value="False" />
                        <Setter Target="OverlayToolbar.Visibility" Value="Visible" />
                        <Setter Target="CompactNavigationButton.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Border
            x:Name="NavigationPane"
            Grid.Column="0"
            Padding="16"
            Background="{ThemeResource Pi67SurfaceBrush}"
            BorderBrush="{ThemeResource Pi67DividerBrush}"
            BorderThickness="0,0,1,0">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Uid="ProjectsHeading" Style="{StaticResource Pi67SectionTitleStyle}" />
                <Border Grid.Row="1" Padding="12" Style="{StaticResource Pi67PanelStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding WorkspaceDisplayName}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding WorkspacePath}"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="OpenWorkspaceButton" x:Uid="OpenWorkspaceButton" Click="OnOpenWorkspaceClick" />
                    <Button x:Name="NewSessionButton" x:Uid="NewSessionButton" Click="OnNewSessionClick" />
                </StackPanel>
                <ListView
                    x:Name="SessionList"
                    x:Uid="SessionList"
                    Grid.Row="3"
                    ItemsSource="{Binding Sessions}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE8A5;" FontSize="13" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding LastOpenedAt}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button
                    x:Name="OpenSessionButton"
                    x:Uid="OpenSessionButton"
                    Grid.Row="4"
                    HorizontalAlignment="Stretch"
                    Click="OnOpenSessionClick" />
            </Grid>
        </Border>

        <SplitView
            x:Name="ContextSplitView"
            Grid.Column="1"
            CompactPaneLength="0"
            DisplayMode="Inline"
            IsPaneOpen="True"
            OpenPaneLength="360"
            PanePlacement="Right">
            <SplitView.Content>
        <Grid Background="{ThemeResource Pi67CanvasBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,12,16,0" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <InfoBar
                    x:Name="RuntimeInfoBar"
                    x:Uid="RuntimeInfoBar"
                    IsClosable="False"
                    IsOpen="True"
                    Severity="Informational"
                    Title="{Binding RuntimeStatus}"
                    Message="{Binding RuntimeDetail}" />
                <StackPanel
                    x:Name="OverlayToolbar"
                    Grid.Column="1"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Spacing="6"
                    Visibility="Collapsed">
                    <Button x:Name="CompactNavigationButton" x:Uid="CompactNavigationButton" Visibility="Collapsed">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <Grid Width="320" Height="480" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding WorkspaceDisplayName}" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding WorkspacePath}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                        <Button x:Uid="CompactOpenWorkspaceButton" Click="OnOpenWorkspaceClick" />
                                        <Button x:Uid="CompactNewSessionButton" Click="OnNewSessionClick" />
                                    </StackPanel>
                                    <ListView
                                        x:Name="CompactSessionList"
                                        Grid.Row="2"
                                        ItemsSource="{Binding Sessions}"
                                        SelectionMode="Single">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Padding="6">
                                                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding LastOpenedAt}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <Button
                                        x:Uid="CompactOpenSessionButton"
                                        Grid.Row="3"
                                        HorizontalAlignment="Stretch"
                                        Click="OnOpenCompactSessionClick" />
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button x:Name="ContextToggleButton" x:Uid="ContextToggleButton" Click="OnContextToggleClick" />
                </StackPanel>
            </Grid>

            <ListView
                x:Name="TranscriptList"
                x:Uid="TranscriptList"
                Grid.Row="1"
                Padding="20,16"
                IsItemClickEnabled="False"
                ItemsSource="{Binding Transcript}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,16" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{Binding Author}" />
                            <controls:NativeMarkdownView
                                Grid.Column="1"
                                Markdown="{Binding Markdown}"
                                IsStreaming="{Binding IsStreaming}"
                                ExternalLinkRequested="OnExternalLinkRequested" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Border
                Grid.Row="2"
                Margin="16,0,16,12"
                Padding="12"
                Style="{StaticResource Pi67PanelStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ItemsControl ItemsSource="{Binding Attachments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,8,8"
                                    Padding="8,4"
                                    Background="{ThemeResource Pi67SurfaceBrush}"
                                    BorderBrush="{ThemeResource Pi67DividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{ThemeResource Pi67ControlRadius}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xEB9F;" FontSize="12" />
                                        <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{Binding DisplaySize}" />
                                        <Button
                                            x:Uid="RemoveAttachmentButton"
                                            Padding="4,0"
                                            Tag="{Binding Id}"
                                            Click="OnRemoveAttachmentClick" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBox
                        x:Name="Composer"
                        x:Uid="ComposerTextBox"
                        Grid.Row="1"
                        AcceptsReturn="True"
                        MinHeight="88"
                        Text="{Binding ComposerText, Mode=TwoWay}"
                        TextWrapping="Wrap"
                        KeyDown="OnComposerKeyDown" />
                    <Grid Grid.Row="2">
                        <Button
                            x:Name="AttachImageButton"
                            x:Uid="AttachImageButton"
                            HorizontalAlignment="Left"
                            Click="OnAttachImageClick" />
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                        <Button
                            x:Name="StopButton"
                            x:Uid="StopButton"
                            IsEnabled="{Binding IsSessionActive}"
                            Click="OnStopClick" />
                        <Button
                            x:Name="SendButton"
                            x:Uid="SendButton"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="{Binding IsSessionActive}"
                            Click="OnSendClick" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border
                Grid.Row="3"
                Padding="16,8"
                Background="{ThemeResource Pi67SurfaceBrush}"
                BorderBrush="{ThemeResource Pi67DividerBrush}"
                BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock
                        x:Name="OperationStatusText"
                        x:Uid="OperationStatusText"
                        AutomationProperties.LiveSetting="Polite"
                        Text="{Binding OperationStatus}" />
                    <ProgressRing
                        HorizontalAlignment="Right"
                        Width="18"
                        Height="18"
                        IsActive="{Binding IsBusy}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
                </Grid>
            </Border>
        </Grid>
            </SplitView.Content>
            <SplitView.Pane>

        <Border
            x:Name="ContextPane"
            Padding="12"
            Background="{ThemeResource Pi67SurfaceBrush}"
            BorderBrush="{ThemeResource Pi67DividerBrush}"
            BorderThickness="1,0,0,0">
            <TabView IsAddTabButtonVisible="False">
                <TabViewItem x:Uid="ActivityTab" IsClosable="False">
                    <ListView x:Uid="ToolActivityList" ItemsSource="{Binding ToolActivities}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8" Spacing="4">
                                    <Grid>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding ToolName}" />
                                        <TextBlock HorizontalAlignment="Right" Text="{Binding Status}" />
                                    </Grid>
                                    <TextBlock
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Detail}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>
                <TabViewItem x:Uid="SettingsTab" IsClosable="False">
                    <ScrollViewer>
                        <StackPanel Padding="8" Spacing="16">
                            <StackPanel Spacing="6">
                                <TextBlock x:Uid="ProjectTrustHeading" Style="{StaticResource Pi67SectionTitleStyle}" />
                                <TextBlock Text="{Binding TrustStatus}" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button x:Uid="TrustOnceButton" Click="OnTrustOnceClick" />
                                    <Button x:Uid="TrustPersistButton" Click="OnTrustPersistClick" />
                                    <Button x:Uid="DenyTrustButton" Click="OnDenyTrustClick" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock x:Uid="AuthenticationHeading" Style="{StaticResource Pi67SectionTitleStyle}" />
                                <ItemsControl ItemsSource="{Binding AuthProviders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4" Spacing="4">
                                                <Grid>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding ProviderId}" />
                                                    <TextBlock HorizontalAlignment="Right" Text="{Binding StatusText}" />
                                                </Grid>
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding AccountLabel}" />
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <Button
                                                        x:Uid="SetApiKeyButton"
                                                        IsEnabled="{Binding SupportsApiKey}"
                                                        Tag="{Binding}"
                                                        Click="OnSetApiKeyClick" />
                                                    <Button
                                                        x:Uid="OAuthButton"
                                                        IsEnabled="{Binding SupportsOAuth}"
                                                        Tag="{Binding}"
                                                        Click="OnOAuthClick" />
                                                    <Button
                                                        x:Uid="LogoutButton"
                                                        IsEnabled="{Binding Configured}"
                                                        Tag="{Binding}"
                                                        Click="OnLogoutClick" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock x:Uid="ModelsHeading" Style="{StaticResource Pi67SectionTitleStyle}" />
                                    <Button
                                        x:Uid="RefreshModelsButton"
                                        HorizontalAlignment="Right"
                                        Padding="8,2"
                                        Click="OnRefreshModelsClick" />
                                </Grid>
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{Binding DefaultModelStatus}" />
                                <ItemsControl ItemsSource="{Binding Models}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2" ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{Binding QualifiedId}" />
                                                </StackPanel>
                                                <Button
                                                    x:Uid="SetDefaultModelButton"
                                                    Grid.Column="1"
                                                    Tag="{Binding}"
                                                    Click="OnSetDefaultModelClick" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabViewItem>
                <TabViewItem x:Uid="DiagnosticsTab" IsClosable="False">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                    <ListView ItemsSource="{Binding BootstrapSteps}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8" Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Source}" />
                                    <TextBlock
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Text="{Binding ExactCommand}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Status}" />
                                    <TextBlock
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                        Text="{Binding FailureMessage}"
                                        TextWrapping="Wrap" />
                                    <Button
                                        x:Uid="RunBootstrapStepButton"
                                        HorizontalAlignment="Left"
                                        Tag="{Binding}"
                                        Click="OnBootstrapStepClick" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                        <Button
                            x:Uid="CancelBootstrapButton"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding IsBootstrapRunning}"
                            Click="OnCancelBootstrapClick" />
                    </Grid>
                </TabViewItem>
            </TabView>
        </Border>
            </SplitView.Pane>
        </SplitView>
    </Grid>
</Page>
