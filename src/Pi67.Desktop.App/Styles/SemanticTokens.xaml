<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Pi67CanvasBrush" Color="{ThemeResource SolidBackgroundFillColorBase}" />
    <SolidColorBrush x:Key="Pi67TitleBarBrush" Color="{ThemeResource SolidBackgroundFillColorBaseAlt}" />
    <SolidColorBrush x:Key="Pi67SurfaceBrush" Color="{ThemeResource LayerFillColorDefault}" />
    <SolidColorBrush x:Key="Pi67RaisedSurfaceBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />
    <SolidColorBrush x:Key="Pi67DividerBrush" Color="{ThemeResource DividerStrokeColorDefault}" />
    <SolidColorBrush x:Key="Pi67CodeBrush" Color="{ThemeResource LayerFillColorAlt}" />
    <CornerRadius x:Key="Pi67ControlRadius">4</CornerRadius>
    <CornerRadius x:Key="Pi67PanelRadius">8</CornerRadius>
</ResourceDictionary>
