<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="Pi67SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="CharacterSpacing" Value="40" />
    </Style>
    <Style x:Key="Pi67PanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource Pi67SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource Pi67DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{ThemeResource Pi67PanelRadius}" />
    </Style>
</ResourceDictionary>
