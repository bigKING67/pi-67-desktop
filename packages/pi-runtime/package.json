{
  "name": "@pi67/pi-runtime",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --deps.never-bundle @earendil-works/pi-coding-agent --deps.never-bundle @earendil-works/pi-agent-core --deps.never-bundle @earendil-works/pi-ai",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.81.1",
    "@earendil-works/pi-ai": "0.81.1",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "@pi67/domain": "workspace:*",
    "@pi67/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "tsdown": "0.22.13",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
